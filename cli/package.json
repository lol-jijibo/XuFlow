{
  "name": "xuflow-cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "xuflow": "./bin/xuflow.js"
  },
  "napi": {
    "name": "xuflow-napi",
    "triples": {
      "defaults": true
    }
  },
  "scripts": {
    "dev": "node bin/xuflow.js",
    "build": "tsc",
    "build:napi": "napi build --platform --release --js false --pipe \"prefer-static\""
  },
  "dependencies": {
    "ink": "^5.2",
    "react": "^19.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.1",
    "@types/react": "^19.1",
    "typescript": "^5.7"
  }
}
